#!/bin/bash

WORK_MINUTES=25
BREAK_MINUTES=5
LONG_BREAK_MINUTES=15
WORK_BEFORE_LONG_BREAK=4

SESSIONS_FILE="${HOME}/.cache/.pomodoro_sessions"

# Initialize session count
[ ! -f "$SESSIONS_FILE" ] && echo 0 > "$SESSIONS_FILE"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "Pomodoro" "$1"
    else
        echo "$1"
    fi
}

run_timer() {
    local label="$1"
    local minutes="$2"
    local seconds=$((minutes * 60))

    echo "$label session: $minutes minutes"
    while [ $seconds -gt 0 ]; do
        printf "\r%02d:%02d remaining" $((seconds/60)) $((seconds%60))
        sleep 1
        ((seconds--))
    done
    echo ""
    notify "$label finished."
}

increment_session() {
    local count
    count=$(cat "$SESSIONS_FILE")
    ((count++))
    echo "$count" > "$SESSIONS_FILE"
}

reset_sessions() {
    echo 0 > "$SESSIONS_FILE"
}

get_session_count() {
    cat "$SESSIONS_FILE"
}

while true; do
    echo "Current completed work sessions: $(get_session_count)"
    echo "1) Start next timer (auto-select)"
    echo "2) Manual Work ($WORK_MINUTES min)"
    echo "3) Manual Break ($BREAK_MINUTES min)"
    echo "4) Reset work session count"
    echo "5) Quit"
    read -rp "Choose an option: " choice

    case "$choice" in
        1)
            work_sessions=$(get_session_count)
            if (( work_sessions > 0 && work_sessions % WORK_BEFORE_LONG_BREAK == 0 )); then
                run_timer "Long Break" "$LONG_BREAK_MINUTES"
            elif (( work_sessions == 0 )) || (( work_sessions % 2 == 0 )); then
                run_timer "Work" "$WORK_MINUTES"
                increment_session
            else
                run_timer "Break" "$BREAK_MINUTES"
            fi
            ;;
        2)
            run_timer "Work" "$WORK_MINUTES"
            increment_session
            ;;
        3)
            run_timer "Break" "$BREAK_MINUTES"
            ;;
        4)
            reset_sessions
            echo "Work session count reset."
            ;;
        5)
            echo "Exiting."
            exit 0
            ;;
        *)
            echo "Invalid input."
            ;;
    esac
done

